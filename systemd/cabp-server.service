[Unit]
Description=CABP Node Server (Backend API)
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/calvin/Repo1/server
EnvironmentFile=-/etc/cabp.env
# Ensure a sensible PATH for systemd (installer will replace PATH if node is detected)
Environment=PATH=/home/calvin/.nvm/versions/node/v20.20.1/bin:/usr/local/bin:/usr/bin:/bin
Environment=NODE_ENV=production
Environment=HOST=100.81.83.98
Environment=PORT=5000
# Run the server directly with node to avoid relying on npm availability in PATH
ExecStart=/home/calvin/.nvm/versions/node/v20.20.1/bin/node src/index.js
Restart=always
RestartSec=5
StandardOutput=append:/var/log/cabp-server.log
StandardError=append:/var/log/cabp-server.log
# The installer replaces REPLACE_USER with the user who owns the checkout
User=calvin
KillMode=process

[Install]
WantedBy=multi-user.target
